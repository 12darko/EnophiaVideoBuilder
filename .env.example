# ============================================================
# Otonom Video Fabrikası — Ortam Değişkenleri Şablonu
# ============================================================
# Bu dosyayı ".env" olarak kopyalayın veya
# Coolify arayüzünden "Environment Variables" bölümüne yapıştırın.
#
# ⚠️ API anahtarlarını buraya yazın — boş bırakılmış olanları
#    doldurmadan sistem çalışmaz!
# ============================================================

# ┌──────────────────────────────────────────────────────────┐
# │                   ZORUNLU AYARLAR                        │
# │            (Bunları doldurmadan sistem çalışmaz)          │
# └──────────────────────────────────────────────────────────┘

# ── LLM (Yapay Zeka Beyni) ──────────────────────────────────
# Agent'ın konu/senaryo üretmesi için gerekli.
# Desteklenen: gemini, openai, deepseek
LLM_PROVIDER=gemini
LLM_API_KEY=BURAYA_GEMINI_API_KEY_YAZIN
LLM_MODEL_NAME=gemini-2.0-flash

# OpenAI/DeepSeek kullanacaksanız (LLM_PROVIDER=openai ise):
# LLM_OPENAI_API_KEY=sk-xxxx
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_MODEL_NAME=gpt-4o-mini

# ── MoneyPrinterTurbo anahtarları (env → config.toml, KALICI) ──
# ÖNEMLİ: Bunları doldurursan UI'dan girmene gerek YOK ve redeploy'da
# ASLA SİLİNMEZ (her açılışta env'den config.toml'a işlenir).
# UI'dan girmeyi tercih edersen boş bırak.
PEXELS_API_KEY=
GEMINI_API_KEY=
# PIXABAY_API_KEY=
# GEMINI_MODEL_NAME=gemini-2.0-flash
# VIDEO_SOURCE=pexels

# MPT UI'da gösterilecek "Agent Paneli" linki (opsiyonel)
# Örn: https://panel.domainin.com:8090  veya  http://SUNUCU_IP:8090
# PANEL_URL=

# ┌──────────────────────────────────────────────────────────┐
# │               İÇERİK STRATEJİSİ                         │
# └──────────────────────────────────────────────────────────┘

# İçerik dili: tr (Türkçe), en (İngilizce)
CONTENT_LANGUAGE=tr

# İçerik niche'i: motivation, finance, tech, education, travel, health, comedy
CONTENT_NICHE=motivation

# Belirli konular (virgülle ayrılmış, boşsa LLM otomatik üretir)
# Örnek: CONTENT_TOPIC_POOL=Başarının sırrı,Para yönetimi,Zaman kullanımı
CONTENT_TOPIC_POOL=

# Hedef video süresi (saniye)
CONTENT_TARGET_DURATION_SECONDS=60

# ┌──────────────────────────────────────────────────────────┐
# │              ZAMANLAMA (SCHEDULER)                       │
# └──────────────────────────────────────────────────────────┘

# Günlük üretilecek video sayısı
SCHEDULER_DAILY_VIDEO_COUNT=3

# Video üretim saatleri (UTC+3 İstanbul, virgülle ayrılmış)
# Varsayılan: Sabah 09:00, Öğlen 14:00, Akşam 19:00
SCHEDULER_PRODUCTION_HOURS=9,14,19

# Video üretildikten kaç dakika sonra sosyal medyaya paylaşılsın
SCHEDULER_POST_DELAY_MINUTES=5

# İki video arası minimum bekleme (dakika)
SCHEDULER_MIN_INTERVAL_MINUTES=60

# ┌──────────────────────────────────────────────────────────┐
# │            SOSYAL MEDYA PLATFORMLARI                     │
# └──────────────────────────────────────────────────────────┘

# Aktif platformlar (virgülle ayrılmış)
# Sadece ayarlarını doldurduğunuz platformlar çalışır
SOCIAL_ENABLED_PLATFORMS=tiktok,instagram,youtube

# Paylaşım stratejisi: api (resmi API), browser (browser-use), hybrid
SOCIAL_PUBLISH_STRATEGY=hybrid

# Varsayılan hashtag'ler
SOCIAL_DEFAULT_HASHTAGS=#shorts,#viral,#ai,#fyp

# ── TikTok ──────────────────────────────────────────────────
# browser-use ile paylaşım için TikTok oturum cookie'si.
# Tarayıcıda TikTok'a giriş yapıp cookie'yi kopyalayın.
# Desteklenen 3 format (sistem otomatik algılar):
#   1) Header dizgisi (önerilen):  sessionid=ABC; tt_csrf_token=XYZ
#   2) Tek değer (yalnızca sessionid):  ABC123...
#   3) JSON dizisi (tarayıcı eklentisi ihracı):  [{"name":"sessionid",...}]
# En sağlıklısı en az "sessionid" çerezini vermek; mümkünse tüm oturum
# çerezlerini header formatında verin (sessionid + tt_csrf vb.).
SOCIAL_TIKTOK_SESSION_COOKIE=

# ── Instagram ───────────────────────────────────────────────
# browser-use ile paylaşım için Instagram kimlik bilgileri
SOCIAL_INSTAGRAM_USERNAME=
SOCIAL_INSTAGRAM_PASSWORD=

# ── YouTube ─────────────────────────────────────────────────
# YouTube Data API v3 OAuth2 kimlik bilgileri
# Google Cloud Console'dan oluşturun:
# https://console.cloud.google.com/apis/credentials
SOCIAL_YOUTUBE_CLIENT_ID=
SOCIAL_YOUTUBE_CLIENT_SECRET=
SOCIAL_YOUTUBE_REFRESH_TOKEN=

# ┌──────────────────────────────────────────────────────────┐
# │          HATA YÖNETİMİ (SELF-HEALING)                   │
# └──────────────────────────────────────────────────────────┘

# Maksimum yeniden deneme sayısı
HEAL_MAX_RETRIES=5

# İlk bekleme süresi (saniye) — her denemede 2x artar
HEAL_INITIAL_BACKOFF_SECONDS=30

# Maksimum bekleme süresi (saniye)
HEAL_MAX_BACKOFF_SECONDS=600

# OOM algılandığında bekleme süresi (saniye)
HEAL_OOM_COOLDOWN_SECONDS=300

# ┌──────────────────────────────────────────────────────────┐
# │             BİLDİRİMLER (OPSİYONEL)                     │
# └──────────────────────────────────────────────────────────┘

# Telegram bildirimleri (kritik hatalarda uyarı almak için)
NOTIFY_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# ┌──────────────────────────────────────────────────────────┐
# │          DEPOLAMA / OTOMATİK TEMİZLİK                    │
# └──────────────────────────────────────────────────────────┘

# Kaç günden eski videolar otomatik silinsin (0 = kapalı)
STORAGE_RETENTION_DAYS=7

# Toplam depolama bu GB'ı aşınca en eskiler silinsin (0 = kapalı)
STORAGE_MAX_STORAGE_GB=0

# ┌──────────────────────────────────────────────────────────┐
# │            WEB KONTROL PANELİ                            │
# └──────────────────────────────────────────────────────────┘
# Durum izleme + video listele/izle/sil + "şu konuda üret" tetikleme.
# Panel ai-agent üzerinde :8090 portunda çalışır.

PANEL_ENABLED=true
# ⚠️ ŞİFRE BOŞSA panel salt-okunur olur (üret/sil çalışmaz).
# Mutlaka güçlü bir şifre koy (panel domaine açılırsa kritik!):
PANEL_USERNAME=admin
PANEL_PASSWORD=

# ┌──────────────────────────────────────────────────────────┐
# │              AGENT GENEL AYARLARI                        │
# └──────────────────────────────────────────────────────────┘

# İlk başlangıçta test video üretimi yapsın mı?
AGENT_RUN_ON_START=false

# Timezone
TZ=Europe/Istanbul
